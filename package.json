{
  "name": "secure-ui-components",
  "version": "0.3.0",
  "description": "Security-first web component library with zero dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./secure-input": {
      "types": "./dist/components/secure-input/secure-input.d.ts",
      "import": "./dist/components/secure-input/secure-input.js"
    },
    "./secure-textarea": {
      "types": "./dist/components/secure-textarea/secure-textarea.d.ts",
      "import": "./dist/components/secure-textarea/secure-textarea.js"
    },
    "./secure-select": {
      "types": "./dist/components/secure-select/secure-select.d.ts",
      "import": "./dist/components/secure-select/secure-select.js"
    },
    "./secure-form": {
      "types": "./dist/components/secure-form/secure-form.d.ts",
      "import": "./dist/components/secure-form/secure-form.js"
    },
    "./secure-file-upload": {
      "types": "./dist/components/secure-file-upload/secure-file-upload.d.ts",
      "import": "./dist/components/secure-file-upload/secure-file-upload.js"
    },
    "./secure-datetime": {
      "types": "./dist/components/secure-datetime/secure-datetime.d.ts",
      "import": "./dist/components/secure-datetime/secure-datetime.js"
    },
    "./secure-table": {
      "types": "./dist/components/secure-table/secure-table.d.ts",
      "import": "./dist/components/secure-table/secure-table.js"
    },
    "./secure-submit-button": {
      "types": "./dist/components/secure-submit-button/secure-submit-button.d.ts",
      "import": "./dist/components/secure-submit-button/secure-submit-button.js"
    },
    "./secure-card": {
      "types": "./dist/components/secure-card/secure-card.d.ts",
      "import": "./dist/components/secure-card/secure-card.js"
    },
    "./secure-telemetry-provider": {
      "types": "./dist/components/secure-telemetry-provider/secure-telemetry-provider.d.ts",
      "import": "./dist/components/secure-telemetry-provider/secure-telemetry-provider.js"
    },
    "./secure-password-confirm": {
      "types": "./dist/components/secure-password-confirm/secure-password-confirm.d.ts",
      "import": "./dist/components/secure-password-confirm/secure-password-confirm.js"
    },
    "./base-component": {
      "types": "./dist/core/base-component.d.ts",
      "import": "./dist/core/base-component.js"
    },
    "./security-config": {
      "types": "./dist/core/security-config.d.ts",
      "import": "./dist/core/security-config.js"
    },
    "./tokens.css": "./dist/styles/tokens.css",
    "./secure-ui.css": "./dist/styles/secure-ui.css",
    "./bundle": "./dist/secure-ui.bundle.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc",
    "build:css": "node build/css-inliner.js",
    "build:minify": "node build/js-minifier.js",
    "build:bundle": "node build/bundler.js",
    "build": "npm run clean && npm run build:ts && npm run build:css && npm run build:minify && npm run build:bundle",
    "build:dev": "npm run build:ts && node build/dev-build.js",
    "serve": "node server.js",
    "serve:dev": "node --watch server.js",
    "start": "npm run build && npm run serve",
    "dev": "npm run build && npm run serve:dev",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:build": "vitest run --config vitest.build.config.ts",
    "size": "size-limit",
    "audit:check": "npm audit --audit-level=high",
    "test:e2e": "npm run build:ts && npx playwright test",
    "test:e2e:headed": "npm run build:ts && npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:build"
  },
  "keywords": [
    "web-components",
    "security",
    "ui",
    "form-components",
    "typescript",
    "progressive-enhancement",
    "zero-dependencies",
    "xss-prevention",
    "audit-logging",
    "input-validation",
    "shadow-dom",
    "custom-elements"
  ],
  "author": "Barry Prendergast <barryprendergast@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Barryprender/Secure-UI.git"
  },
  "bugs": {
    "url": "https://github.com/Barryprender/Secure-UI/issues"
  },
  "homepage": "https://github.com/Barryprender/Secure-UI#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "axe-core": "^4.11.1",
    "cors": "^2.8.5",
    "esbuild": "^0.28.0",
    "eslint-plugin-security": "^4.0.0",
    "express": "^4.18.2",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "size-limit": "^12.0.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "flatted": "^3.4.2"
  }
}
